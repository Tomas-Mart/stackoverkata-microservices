DEV_LOG_LEVEL=DEBUG
TEST_LOG_LEVEL=DEBUG

#######################################
###      НАСТРОЙКИ RESILIENCE4J     ###
#######################################

CIRCUIT_BREAKER_SLIDING_WINDOW_SIZE=10
CIRCUIT_BREAKER_MINIMUM_NUMBER_OF_CALLS=5
CIRCUIT_BREAKER_FAILURE_RATE_THRESHOLD=50
CIRCUIT_BREAKER_WAIT_DURATION_IN_OPEN_STATE=10s

#######################################
###      НАСТРОЙКИ FEIGN            ###
#######################################

FEIGN_CIRCUIT_BREAKER_ENABLED=true
FEIGN_CLIENT_CONFIG_READ_TIMEOUT=60000
FEIGN_CLIENT_CONFIG_CONNECT_TIMEOUT=5000

